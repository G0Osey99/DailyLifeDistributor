# Secrets and credentials
.env
client_secrets.json
token.json
*_session.json

# Local state
state.db
state.db-journal
logs/

# Browser-automation debug artifacts (form recons + failure screenshots)
rock_failure_*.png
rock_email_form.png
rock_email_form.html
rock_email_form_fields.json
rock_email_mcp_filled.png
_mcp_cookies.json
