# Copy to deploy/.env (gitignored) and fill in. Used by docker-compose.yml.

# Fernet master key for the encrypted secret store. REQUIRED. Losing it makes
# the stored secrets/sessions unrecoverable. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENC_KEY=

# Shared login password set on first boot. REQUIRED (changeable later in Settings).
INITIAL_ADMIN_PASSWORD=

# Flask session-signing key. REQUIRED when HOSTED=true (startup fails without
# it) — a stable key keeps logins alive across restarts/redeploys. Generate:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Send the session cookie only over HTTPS. Cloudflare terminates TLS in front
# of the app, so leave this "true" in the hosted deploy.
SESSION_COOKIE_SECURE=true

# Public hostname; the app rejects requests with any other Host (DNS-rebind guard).
ALLOWED_HOSTS=autoalert.pro

# Cloudflare Tunnel connector token (Zero-Trust → Tunnels → your tunnel). REQUIRED.
# The public-hostname route (autoalert.pro → http://dld-caddy:80) is set in the
# Cloudflare dashboard, not here.
TUNNEL_TOKEN=

# Free-stock-image keys for the Rock spotlight/vista/reflection slots
# (see core/image_gatherer.py). Both are OPTIONAL — when unset the
# image gatherer logs a debug line and skips that provider. Unsplash
# is the primary path; Pexels is the fallback. These are read-only
# public API keys; do NOT add the Unsplash "secret" key — only the
# *access* key is consumed.
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Optional overrides (compose already sets sane defaults in the app service):
#   HOSTED=true  DLD_STATE_DB=/data/state.db
#   LLM_BASE_URL=http://ollama:11434  LLM_MODEL=llama3.2
#   HYBRID_AGENT_ENABLED=true   # enable the hybrid upload-agent relay
